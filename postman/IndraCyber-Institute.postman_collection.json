              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"student@example.com\",\n  \"password\": \"Password123!\",\n  \"firstName\": \"Demo\",\n  \"lastName\": \"Student\",\n  \"phone\": \"99000000\"\n}"
            },
            "url": {
              "raw": "{{gatewayUrl}}/api/auth/register"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "if (body && body.data && body.data.token) {",
                  "  pm.environment.set('token', body.data.token);",
                  "}",
                  "if (body && body.data && body.data.user && body.data.user.id) {",
                  "  pm.environment.set('userId', String(body.data.user.id));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": {
              "raw": "{{gatewayUrl}}/api/auth/login"
            }
          }
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{gatewayUrl}}/api/auth/me"
            }
          }
        },
        {
